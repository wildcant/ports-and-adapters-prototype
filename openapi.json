        "required": [
          "id",
          "first_name",
          "last_name",
          "email",
          "created_at",
          "updated_at",
          "deleted_at"
        ]
      },
      "CreateCustomer": {
        "type": "object",
        "properties": {
          "first_name": {
            "type": "string",
            "minLength": 1
