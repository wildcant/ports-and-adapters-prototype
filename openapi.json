            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "customers": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Customer"
                      }
                    },
                    "count": {
                      "type": "number"
                    }
                  },
                  "required": [
                    "customers",
                    "count"
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Validation error"
          }
        }
      },
      "post": {
