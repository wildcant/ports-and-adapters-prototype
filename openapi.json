        "required": [
          "first_name",
          "last_name",
          "email"
        ]
      },
      "UpdateCustomer": {
        "type": "object",
        "properties": {
          "first_name": {
            "type": "string",
            "minLength": 1
          },
          "last_name": {
            "type": "string",
            "minLength": 1
          },
          "email": {
            "type": "string",
            "format": "email"
          }
        }
      }
    },
    "parameters": {}
