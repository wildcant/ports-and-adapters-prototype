{
  "name": "backend",
  "private": true,
  "type": "module",
  "exports": {
    "./container": "./src/container.ts"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:generate:supabase": "drizzle-kit generate --config=drizzle.config.supabase.ts",
    "db:migrate:supabase": "drizzle-kit migrate --config=drizzle.config.supabase.ts",
    "db:setup": "drizzle-kit migrate && prisma generate --schema=prisma/schema.prisma"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.0",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "awilix": "^12.0.0",
    "better-sqlite3": "^11.0.0",
    "drizzle-orm": "^0.39.0",
    "express": "^4.21.0",
    "hono": "^4.12.0",
    "postgres": "^3.4.7",
    "prisma": "^7.8.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^5.0.0",
    "drizzle-kit": "^0.31.0",
    "tsx": "^4.19.0",
    "typescript": "^7.0.0",
    "vitest": "^4.1.10"
  }
}
