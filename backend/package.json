{
  "name": "backend",
  "private": true,
  "type": "module",
  "exports": {
    "./container": "./container.ts"
  },
  "scripts": {
    "start": "tsx index.ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
