{
  "name": "backend",
  "private": true,
  "type": "module",
  "exports": {
    "./api": "./src/api/index.ts",
    "./validators": "./src/core/http-schemas/index.ts"
  },
  "scripts": {
    "start": "dotenvx run -f ../.env -- tsx src/index.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "db:start": "supabase start",
    "db:start:lean": "supabase start -x studio,imgproxy,inbucket,edge-runtime,functions,analytics,vector,realtime,storage,meta",
    "db:stop": "supabase stop",
    "db:status": "supabase status",
    "db:reset": "supabase db reset",
    "db:migrate:user": "dotenvx run -f ../.env -- drizzle-kit migrate --config=src/modules/user/drizzle.config.ts",
    "db:migrate:customer": "dotenvx run -f ../.env -- drizzle-kit migrate --config=src/modules/customer/drizzle.config.ts",
    "openapi:dump": "curl -s http://localhost:3000/openapi.json | python3 -m json.tool > ../openapi.json && echo 'Saved to openapi.json'",
    "openapi:dump:offline": "tsx src/scripts/openapi-dump.ts"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@dotenvx/dotenvx": "^2.14.0",
    "@hono/node-server": "^2.0.0",
    "awilix": "^12.0.0",
    "drizzle-orm": "^0.39.0",
    "express": "^4.21.0",
    "hono": "^4.12.0",
    "postgres": "^3.4.7",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.5.0",
    "@types/express": "^5.0.0",
    "@types/swagger-ui-express": "^4.1.8",
    "drizzle-kit": "^0.31.0",
    "supabase": "^2.109.1",
    "tsx": "^4.19.0",
    "typescript": "^7.0.0",
    "vitest": "^4.1.10"
  }
}
